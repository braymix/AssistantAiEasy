# =============================================================================
# KnowledgeHub Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment

# Profile: "mini" for single-machine/mini-PC, "full" for enterprise
KNOWLEDGEHUB_PROFILE=mini

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
GATEWAY_PORT=8000
ADMIN_PORT=8001
OLLAMA_PORT=11434
CHROMA_PORT=8100
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
POSTGRES_PORT=5432
VLLM_PORT=8080

# -----------------------------------------------------------------------------
# Database (mini: SQLite, full: PostgreSQL)
# -----------------------------------------------------------------------------
# Mini profile (default):
DATABASE_URL=sqlite+aiosqlite:///./data/sqlite/knowledgehub.db

# Full profile (uncomment):
# DATABASE_URL=postgresql+asyncpg://knowledgehub:changeme@postgres:5432/knowledgehub
# POSTGRES_DB=knowledgehub
# POSTGRES_USER=knowledgehub
# POSTGRES_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Vector Store (mini: Chroma, full: Qdrant)
# -----------------------------------------------------------------------------
VECTORSTORE_BACKEND=chroma
CHROMA_HOST=chroma
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333

# -----------------------------------------------------------------------------
# LLM Backend (mini: Ollama, full: vLLM)
# -----------------------------------------------------------------------------
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# Full profile (uncomment):
# LLM_BACKEND=vllm
# VLLM_BASE_URL=http://vllm:8000
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# -----------------------------------------------------------------------------
# Embeddings
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-random-secret-key
API_KEY_HEADER=X-API-Key
# API_KEYS=key1,key2
