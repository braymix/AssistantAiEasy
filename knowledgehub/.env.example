# =============================================================================
# KnowledgeHub Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Variables prefixed with KNOWLEDGEHUB_ are loaded by pydantic-settings.

# ─────────────────────────────────────────────────────────────────────────────
# Profile
# ─────────────────────────────────────────────────────────────────────────────
# mini  = SQLite + Chroma + Ollama (single machine / mini-PC)
# full  = PostgreSQL + Qdrant + vLLM (enterprise / multi-node)
KNOWLEDGEHUB_PROFILE=mini

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
# Mini profile (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./data/sqlite/knowledgehub.db

# Full profile (PostgreSQL – uncomment):
# DATABASE_URL=postgresql+asyncpg://knowledgehub:changeme@postgres:5432/knowledgehub
# POSTGRES_DB=knowledgehub
# POSTGRES_USER=knowledgehub
# POSTGRES_PASSWORD=changeme

# ─────────────────────────────────────────────────────────────────────────────
# Vector Store
# ─────────────────────────────────────────────────────────────────────────────
# chroma = local/embedded (mini)
# qdrant = distributed (full)
VECTORSTORE_BACKEND=chroma
CHROMA_HOST=chroma
CHROMA_PORT=8100
CHROMA_PERSIST_DIR=./data/chroma

# Qdrant (full profile – uncomment):
# VECTORSTORE_BACKEND=qdrant
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333

# ─────────────────────────────────────────────────────────────────────────────
# LLM
# ─────────────────────────────────────────────────────────────────────────────
# ollama = local inference (mini)
# vllm   = GPU inference server (full)
LLM_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=phi3:mini

# vLLM (full profile – uncomment):
# LLM_BACKEND=vllm
# VLLM_BASE_URL=http://vllm:8000
# VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ─────────────────────────────────────────────────────────────────────────────
# Embeddings
# ─────────────────────────────────────────────────────────────────────────────
# local = sentence-transformers (mini, no GPU required)
# ollama = Ollama API embeddings (full)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Ollama embeddings (full profile – uncomment):
# EMBEDDING_BACKEND=ollama
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSION=768

# ─────────────────────────────────────────────────────────────────────────────
# Service Ports
# ─────────────────────────────────────────────────────────────────────────────
GATEWAY_PORT=8000
ADMIN_PORT=8001
OLLAMA_PORT=11434
CHROMA_PORT=8100
# QDRANT_PORT=6333
# QDRANT_GRPC_PORT=6334
# POSTGRES_PORT=5432
# VLLM_PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-in-production
# API_KEY_HEADER=X-API-Key
# API_KEYS=key1,key2

# ─────────────────────────────────────────────────────────────────────────────
# Open WebUI
# ─────────────────────────────────────────────────────────────────────────────
OPENWEBUI_URL=http://open-webui:8080
OPENWEBUI_API_KEY=
# OPENWEBUI_PORT=3000
# OPENWEBUI_AUTH=true
# OPENWEBUI_SECRET=changeme

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
# Levels: DEBUG, INFO, WARNING, ERROR
# Formats: json (structured), console (human-readable)
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─────────────────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key

# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose (used by docker-compose.yml, not by the app directly)
# ─────────────────────────────────────────────────────────────────────────────
# OPENWEBUI_TOKEN=              # Bearer token for Open WebUI API
# VLLM_GPU_MEMORY=0.9           # GPU memory utilization for vLLM
# VLLM_MAX_MODEL_LEN=4096       # Max context length for vLLM
# REDIS_PORT=6379               # Redis port (enterprise only)
